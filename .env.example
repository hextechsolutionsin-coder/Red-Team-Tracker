# =============================================================================
# Red Team Operations Tracker — Environment Variable Reference
# Copy this file to .env and fill in the values before running docker compose up
# =============================================================================

# PostgreSQL connection URL (used by the backend; asyncpg dialect)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://redboard:changeme@db:5432/redboard

# Secret key used to sign session cookies — generate a long random string
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-me-with-a-long-random-secret

# Absolute path inside the backend container where evidence files are stored
# This path is mounted as a Docker volume and is NOT served by nginx
UPLOAD_DIR=/uploads

# Comma-separated list of allowed CORS origins (browser-facing hostnames)
# Example: http://localhost,http://myserver.internal
ALLOWED_ORIGINS=http://localhost

# Host port that nginx (frontend) will be exposed on
FRONTEND_PORT=80

# Host port that the FastAPI backend (Uvicorn) will be exposed on
API_PORT=8000
